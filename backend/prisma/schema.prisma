// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  OWNER
  DISPATCHER
  EMPLOYEE
}

enum VehicleType {
  CAR
  TRUCK
  VAN
  SCOOTER
  BOAT
  OTHER
}

enum VehicleStatus {
  AVAILABLE
  IN_SERVICE
  OUT_OF_ORDER
  MAINTENANCE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model Company {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  users     User[]
  vehicles  Vehicle[]
  tasks     Task[]
  messages  Message[]
}

model User {
  id               Int      @id @default(autoincrement())
  fullName         String
  email            String   @unique
  passwordHash     String
  role             Role     @default(EMPLOYEE)
  phone            String?
  createdAt        DateTime @default(now())

  companyId        Int
  company          Company  @relation(fields: [companyId], references: [id])
  
  // Relatii
  tasksAsAdmin     Task[]   @relation("AdminTasks")
  tasksAsEmployee  Task[]   @relation("EmployeeTasks")
  maintenanceLogs  MaintenanceLog[]
  messages         Message[]
  assignedVehicles Vehicle[] @relation("VehicleDriver")
}

model Vehicle {
  id               Int      @id @default(autoincrement())
  type             VehicleType
  brand            String
  model            String
  licensePlate     String   @unique
  status           VehicleStatus @default(AVAILABLE)
  currentMileage   Float    @default(0)
  currentLat       Float?
  currentLng       Float?
  createdAt        DateTime @default(now())

  companyId        Int
  company          Company  @relation(fields: [companyId], references: [id])

  assignedDriverId Int?
  assignedDriver   User?    @relation("VehicleDriver", fields: [assignedDriverId], references: [id])

  // Relatii
  tasks            Task[]
  maintenanceLogs  MaintenanceLog[]
  documents        Document[]
  obdErrors        OBDError[]
}

model Task {
  id               Int      @id @default(autoincrement())
  title            String
  description      String?
  status           TaskStatus @default(TODO)
  startDate        DateTime?
  endDate          DateTime?
  scheduledStartDate DateTime?
  scheduledEndDate   DateTime?
  pickupLocation     String?
  dropoffLocation    String?
  contactDetails     String?
  address            String?
  lat                Float?
  lng                Float?

  // Relatii (Foreign Keys)
  adminId          Int
  admin            User     @relation("AdminTasks", fields: [adminId], references: [id])
  employeeId       Int
  employee         User     @relation("EmployeeTasks", fields: [employeeId], references: [id])
  companyId        Int
  company          Company  @relation(fields: [companyId], references: [id])
  vehicleId        Int
  vehicle          Vehicle  @relation(fields: [vehicleId], references: [id])
}

model MaintenanceLog {
  id               Int      @id @default(autoincrement())
  reportType       String   // ex: Alimentare, Avarie, Revizie
  description      String
  cost             Float?
  receiptUrl       String?
  reportedAt       DateTime @default(now())

  // Relatii
  vehicleId        Int
  vehicle          Vehicle  @relation(fields: [vehicleId], references: [id])
  employeeId       Int
  employee         User     @relation(fields: [employeeId], references: [id])
}

model Document {
  id               Int      @id @default(autoincrement())
  documentType     String   // ex: RCA, ITP, Rovinieta
  fileUrl          String
  expiresAt        DateTime?
  createdAt        DateTime @default(now())

  // Relatii
  vehicleId        Int
  vehicle          Vehicle  @relation(fields: [vehicleId], references: [id])
}

model OBDError {
  id          Int      @id @default(autoincrement())
  code        String
  description String?
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  vehicleId   Int
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Message {
  id        Int      @id @default(autoincrement())
  text      String
  createdAt DateTime @default(now())

  senderId  Int
  sender    User     @relation(fields: [senderId], references: [id])

  companyId Int
  company   Company  @relation(fields: [companyId], references: [id])
}